---
import { type Lang, t, slugs, LANGUAGES, langConfigs } from '@data/i18n';
interface Props {
  lang: Lang;
  alternates?: { lang: Lang; path: string }[];
}
const { lang, alternates } = Astro.props;
const nav = t(lang, 'nav');

function getLangUrl(targetLang: Lang): string {
  if (alternates) {
    const alt = alternates.find(a => a.lang === targetLang);
    if (alt) return alt.path;
  }
  return `/${targetLang}/`;
}

const navItems = [
  { href: `/${lang}/`, label: nav.home },
  { href: `/${lang}/${slugs.services[lang]}/`, label: nav.services },
  { href: `/${lang}/${slugs.ports[lang]}/`, label: nav.ports },
  { href: `/${lang}/blog/`, label: 'Blog' },
  { href: `/${lang}/${slugs.references[lang]}/`, label: lang === 'tr' ? 'Referanslar' : lang === 'ru' ? 'Партнёры' : lang === 'es' ? 'Referencias' : 'References' },
  { href: `/${lang}/${slugs.about[lang]}/`, label: nav.about },
  { href: `/${lang}/${slugs.contact[lang]}/`, label: nav.contact },
];
---

<!-- Top bar with contact info -->
<div class="hidden md:block bg-navy-950 text-white/60">
  <div class="container-narrow flex items-center justify-between h-9 text-xs font-medium">
    <div class="flex items-center gap-5">
      <a href="tel:+905459477320" class="flex items-center gap-1.5 hover:text-white transition-colors">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        +90 545 947 73 20
      </a>
      <a href="tel:+903624452560" class="flex items-center gap-1.5 hover:text-white transition-colors">
        +90 362 445 25 60
      </a>
      <a href="mailto:info@tokkumanya.com" class="flex items-center gap-1.5 hover:text-white transition-colors">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        info@tokkumanya.com
      </a>
    </div>
    <div class="flex items-center gap-1">
      {LANGUAGES.map(l => (
        <a href={getLangUrl(l)} class={`px-1.5 py-0.5 rounded text-[10px] font-semibold uppercase transition-all ${l === lang ? 'text-white bg-white/15' : 'text-white/40 hover:text-white'}`}>{l}</a>
      ))}
    </div>
  </div>
</div>

<!-- Main Navigation -->
<header id="site-header" class="sticky top-0 z-50 glass shadow-ambient-sm transition-all duration-300">
  <div class="container-narrow">
    <div class="flex items-center justify-between h-16 md:h-[68px]">
      <!-- Logo -->
      <a href={`/${lang}/`} class="flex-shrink-0" aria-label="Tok Ship Supply">
        <img src="/logo/kısa.png" alt="Tok Ship Supply" class="h-9 md:h-10 w-auto" width="260" height="80" loading="eager" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center" aria-label="Main navigation">
        {navItems.map(item => (
          <a href={item.href} class="px-3 xl:px-4 py-2 text-[13px] font-semibold text-on-surface-variant hover:text-primary transition-colors">{item.label}</a>
        ))}
      </nav>

      <!-- Right: WhatsApp CTA -->
      <div class="hidden lg:flex items-center gap-2">
        <a href="https://wa.me/905459477320" target="_blank" rel="noopener noreferrer" class="btn-whatsapp !text-xs !py-2 !px-4 !rounded-lg !gap-1.5">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>

      <!-- Mobile: Language + Menu -->
      <div class="flex lg:hidden items-center gap-2">
        <button id="mobile-menu-btn" class="p-2 rounded-xl text-on-surface-variant hover:bg-surface-container-low" aria-label="Menu" aria-expanded="false">
          <svg id="menu-open-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          <svg id="menu-close-icon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden glass">
    <div class="container-narrow py-3 space-y-0.5">
      {navItems.map(item => (
        <a href={item.href} class="block px-4 py-2.5 text-sm font-semibold text-on-surface-variant rounded-xl hover:bg-surface-container-low hover:text-primary transition-all">{item.label}</a>
      ))}
      <div class="pt-3 flex flex-wrap gap-1.5 px-4">
        {LANGUAGES.map(l => (
          <a href={getLangUrl(l)} class={`px-2.5 py-1.5 text-[11px] font-semibold rounded-lg transition-all ${l === lang ? 'bg-primary text-white' : 'bg-surface-container-low text-on-surface-variant'}`}>{langConfigs[l].flag} {l.toUpperCase()}</a>
        ))}
      </div>
      <div class="pt-3 px-4 pb-1">
        <a href="https://wa.me/905459477320" target="_blank" rel="noopener noreferrer" class="btn-whatsapp w-full text-center !py-2.5 !text-sm">WhatsApp</a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!menu?.classList.contains('hidden')));
  });
</script>
