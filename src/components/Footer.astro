---
import { type Lang, t, slugs, LANGUAGES, langConfigs } from '@data/i18n';
import { services } from '@data/services';
import { ports } from '@data/ports';
import { keywordPatterns } from '@data/keywords';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const footer = t(lang, 'footer');
const nav = t(lang, 'nav');

// Top ports for SEO links
const topPorts = ['istanbul', 'izmir', 'mersin', 'samsun', 'trabzon', 'gemlik', 'aliaga', 'iskenderun', 'antalya', 'tekirdag'];
const topPortData = topPorts.map(id => ports.find(p => p.id === id)).filter(Boolean);
---

<footer class="bg-navy-950 text-gray-400">
  <!-- Main Footer -->
  <div class="container-narrow py-14 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-14">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href={`/${lang}/`} class="inline-block mb-5">
          <img src="/logo/logo.png" alt="Tok Ship Supply" class="h-10 w-auto brightness-0 invert opacity-90" width="280" height="100" loading="lazy" />
        </a>
        <p class="text-sm font-medium leading-relaxed text-gray-500">{footer.description}</p>
        <div class="mt-5 flex items-center gap-3">
          <a href="https://www.instagram.com/tokshipsupply" target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center hover:bg-white/10 transition-all" aria-label="Instagram">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="label text-gray-400 mb-5">{footer.quickLinks}</h3>
        <ul class="space-y-3">
          <li><a href={`/${lang}/`} class="text-sm font-medium text-gray-500 hover:text-white transition-all">{nav.home}</a></li>
          <li><a href={`/${lang}/${slugs.about[lang]}/`} class="text-sm font-medium text-gray-500 hover:text-white transition-all">{nav.about}</a></li>
          <li><a href={`/${lang}/${slugs.ports[lang]}/`} class="text-sm font-medium text-gray-500 hover:text-white transition-all">{nav.ports}</a></li>
          <li><a href={`/${lang}/${slugs.references[lang]}/`} class="text-sm font-medium text-gray-500 hover:text-white transition-all">{lang === 'tr' ? 'Referanslar' : 'References'}</a></li>
          <li><a href={`/${lang}/${slugs.contact[lang]}/`} class="text-sm font-medium text-gray-500 hover:text-white transition-all">{nav.contact}</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="label text-gray-400 mb-5">{footer.ourServices}</h3>
        <ul class="space-y-3">
          {services.map(s => (
            <li><a href={`/${lang}/${slugs.services[lang]}/${slugs.serviceIds[s.id]?.[lang] ?? s.id}/`} class="text-sm font-medium text-gray-500 hover:text-white transition-all">{s.names[lang]}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="label text-gray-400 mb-5">{footer.contactUs}</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 mt-0.5 text-gold-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="text-sm font-medium text-gray-500">Karasamsun Mah. 848.Sok No:2/B<br/>İlkadım, Samsun</span>
          </li>
          <li><a href="tel:+905459477320" class="flex items-center gap-3 text-sm font-medium text-gray-500 hover:text-white transition-all"><svg class="w-4 h-4 text-gold-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>+90 545 947 73 20</a></li>
          <li><a href="tel:+903624452560" class="flex items-center gap-3 text-sm font-medium text-gray-500 hover:text-white transition-all pl-7">+90 362 445 25 60</a></li>
          <li><a href="mailto:info@tokkumanya.com" class="flex items-center gap-3 text-sm font-medium text-gray-500 hover:text-white transition-all"><svg class="w-4 h-4 text-gold-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>info@tokkumanya.com</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4" style="border-top: 1px solid rgba(197, 197, 210, 0.06);">
      <p class="text-xs font-medium text-gray-600">&copy; {new Date().getFullYear()} Tok Ship Supply Co. {footer.rights}</p>
      <div class="flex items-center gap-1.5">
        {LANGUAGES.map(l => (
          <a href={`/${l}/`} class={`label !text-xs px-2 py-1 rounded-lg transition-all ${l === lang ? 'text-white bg-white/10' : 'text-gray-600 hover:text-white'}`}>{l.toUpperCase()}</a>
        ))}
      </div>
    </div>
  </div>

  <!-- SEO Internal Links (bottom of footer) -->
  <div style="border-top: 1px solid rgba(197, 197, 210, 0.04);">
    <div class="container-narrow py-6">
      <div class="flex flex-wrap gap-x-4 gap-y-1">
        {topPortData.map(p => {
          if (!p) return null;
          const pn = p.names[lang];
          return (<>
            <a href={`/${lang}/${slugs.ports[lang]}/${p.id}/${slugs.serviceIds['food-provisions']?.[lang]}/`} class="text-[10px] font-medium text-gray-700 hover:text-gray-400 transition-colors">{pn} {lang === 'tr' ? 'Kumanya' : 'Provisions'}</a>
            <a href={`/${lang}/${slugs.ports[lang]}/${p.id}/${keywordPatterns[0].slugs[lang]}/`} class="text-[10px] font-medium text-gray-700 hover:text-gray-400 transition-colors">{pn} {lang === 'tr' ? 'Gemi Tedarik' : 'Ship Supply'}</a>
            <a href={`/${lang}/${slugs.ports[lang]}/${p.id}/${slugs.serviceIds['fresh-produce']?.[lang]}/`} class="text-[10px] font-medium text-gray-700 hover:text-gray-400 transition-colors">{pn} {lang === 'tr' ? 'Taze Meyve Sebze' : 'Fresh Produce'}</a>
          </>);
        })}
      </div>
    </div>
  </div>
</footer>
