---
import BaseLayout from '@layouts/BaseLayout.astro';
import { LANGUAGES, type Lang, t, tReplace, slugs, getPortSlug, getServiceSlug, getAboutSlug, getContactSlug, langConfigs } from '@data/i18n';
import { ports, regions, getPortsByRegion } from '@data/ports';
import { services } from '@data/services';

export function getStaticPaths() {
  return LANGUAGES.map(lang => ({ params: { lang }, props: { lang } }));
}

const { lang } = Astro.props as { lang: Lang };
const hero = t(lang, 'hero');
const svc = t(lang, 'services');
const prt = t(lang, 'ports');
const about = t(lang, 'about');
const whyUs = t(lang, 'whyUs');
const faq = t(lang, 'faq');
const contact = t(lang, 'contact');

const alternates = LANGUAGES.map(l => ({ lang: l as Lang, path: `/${l}/` }));
const regionOrder = ['marmara', 'aegean', 'mediterranean', 'black-sea'];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.items.map((item: any) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};

const serviceImages = ['food', 'fresh-produce', 'cleaning', 'safety', 'deck', 'technical'];
---

<BaseLayout title={t(lang, 'siteTitle')} description={t(lang, 'siteDescription')} lang={lang} canonicalPath={`/${lang}/`} alternates={alternates} schema={faqSchema}>

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #1A2A60 0%, #243880 40%, #3D5099 100%);">
    <!-- Mobilde arkaplan görseli -->
    <div class="absolute inset-0 lg:hidden">
      <img src="/images/hero.webp" alt="" class="w-full h-full object-cover" loading="eager" aria-hidden="true" />
      <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(26,42,96,0.88) 0%, rgba(36,56,128,0.92) 50%, rgba(61,80,153,0.95) 100%);"></div>
    </div>
    <!-- Maritime pattern overlay -->
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;80&quot; height=&quot;80&quot; viewBox=&quot;0 0 80 80&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23ffffff&quot;%3E%3Ccircle cx=&quot;40&quot; cy=&quot;40&quot; r=&quot;1.5&quot;/%3E%3Ccircle cx=&quot;0&quot; cy=&quot;0&quot; r=&quot;1.5&quot;/%3E%3Ccircle cx=&quot;80&quot; cy=&quot;0&quot; r=&quot;1.5&quot;/%3E%3Ccircle cx=&quot;0&quot; cy=&quot;80&quot; r=&quot;1.5&quot;/%3E%3Ccircle cx=&quot;80&quot; cy=&quot;80&quot; r=&quot;1.5&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>

    <div class="container-narrow relative py-20 md:py-28 lg:py-36">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Content -->
        <div>
          <span class="label-gold">{lang === 'tr' ? 'GÜVENİLİR GEMİ TEDARİK ORTAĞINIZ' : lang === 'ru' ? 'НАДЁЖНЫЙ ПАРТНЁР ПО СНАБЖЕНИЮ СУДОВ' : lang === 'zh' ? '值得信赖的船舶供应合作伙伴' : lang === 'es' ? 'SU SOCIO DE CONFIANZA EN SUMINISTRO MARÍTIMO' : lang === 'ar' ? 'شريككم الموثوق في تموين السفن' : lang === 'fr' ? 'VOTRE PARTENAIRE DE CONFIANCE EN AVITAILLEMENT' : 'TRUSTED SHIP SUPPLY PARTNER'}</span>
          <h1 class="mt-4 text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold text-white leading-[1.1] tracking-tight">
            {hero.title}<span class="text-gold-400">.</span>
          </h1>
          <p class="mt-6 text-lg text-white/60 font-medium leading-relaxed max-w-lg">
            {hero.subtitle}
          </p>
          <div class="mt-10 flex flex-col sm:flex-row gap-3">
            <a href={`/${lang}/${slugs.contact[lang]}/`} class="btn-gold text-base !py-4 !px-8">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
              {lang === 'tr' ? 'Teklif Alın' : lang === 'ru' ? 'Запросить цену' : lang === 'zh' ? '获取报价' : lang === 'es' ? 'Solicitar Cotización' : lang === 'ar' ? 'اطلب عرض سعر' : lang === 'fr' ? 'Demander un Devis' : 'Request a Quote'}
            </a>
            <a href="https://wa.me/905459477320" target="_blank" rel="noopener noreferrer" class="btn-whatsapp text-base !py-4 !px-8">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
          </div>
        </div>

        <!-- Right: Ship Image -->
        <div class="hidden lg:block relative">
          <!-- Decorative accent behind image -->
          <div class="absolute -top-3 -right-3 w-full h-full rounded-2xl" style="background: linear-gradient(135deg, rgba(245,158,11,0.3), rgba(2,136,209,0.2));"></div>
          <div class="relative rounded-2xl overflow-hidden aspect-[4/3] shadow-ambient-lg">
            <img src="/images/hero.webp" alt="Tok Ship Supply - Ship Provisioning at Turkish Port" class="absolute inset-0 w-full h-full object-cover" width="800" height="600" loading="eager" />
            <div class="absolute inset-0 bg-gradient-to-t from-primary/20 to-transparent"></div>
          </div>
          <!-- Floating badge -->
          <div class="absolute -bottom-5 left-6 glass rounded-xl px-5 py-3 shadow-ambient flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #243880, #3D5099);">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <div>
              <div class="text-sm font-extrabold text-on-surface">ISSA Member</div>
              <div class="text-xs font-medium text-on-surface-variant">{lang === 'tr' ? 'Kalite Garantili' : lang === 'ru' ? 'Гарантия качества' : lang === 'zh' ? '质量保证' : lang === 'es' ? 'Calidad Garantizada' : lang === 'ar' ? 'جودة مضمونة' : lang === 'fr' ? 'Qualité Garantie' : 'Quality Guaranteed'}</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Wave -->
    <div class="wave-divider">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-[40px] md:h-[60px] block" fill="#fcf8fb"><path d="M0 60h1440V20Q1080 60 720 40T0 50z"/></svg>
    </div>
  </section>

  <!-- ===== STATS ===== -->
  <section class="py-14 md:py-16 bg-surface">
    <div class="container-narrow">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
        {[
          { num: '20+', label: about.years },
          { num: '28K+', label: about.deliveries },
          { num: '40+', label: about.portsCovered },
          { num: '24/7', label: about.available },
        ].map(stat => (
          <div class="text-center">
            <div class="text-3xl md:text-5xl font-extrabold tracking-tight" style="background: linear-gradient(135deg, #243880, #3D5099); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">{stat.num}</div>
            <div class="mt-2 label">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="py-20 md:py-28 bg-surface-container-low" id="services">
    <div class="container-narrow">
      <span class="label-gold">{lang === 'tr' ? 'HİZMETLERİMİZ' : lang === 'ru' ? 'НАШИ УСЛУГИ' : lang === 'zh' ? '我们的服务' : lang === 'es' ? 'LO QUE SUMINISTRAMOS' : lang === 'ar' ? 'ما نوفره' : lang === 'fr' ? 'NOS SERVICES' : 'WHAT WE SUPPLY'}</span>
      <h2 class="mt-3 section-title">{svc.title}</h2>
      <p class="section-subtitle max-w-2xl">{svc.subtitle}</p>

      <div class="mt-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s, i) => {
          return (
            <a href={`/${lang}/${slugs.services[lang]}/${slugs.serviceIds[s.id]?.[lang] ?? s.id}/`}
               class="group relative rounded-xl bg-surface-container-lowest overflow-hidden transition-all duration-300 hover:shadow-ambient">
              <div class="aspect-[16/9] overflow-hidden">
                <img src={`/images/${serviceImages[i]}.webp`} alt={s.names[lang]} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width="600" height="338" loading="lazy" />
              </div>
              <div class="p-7">
                <h3 class="text-lg font-extrabold text-on-surface group-hover:text-primary transition-colors">{s.names[lang]}</h3>
                <p class="mt-3 text-sm text-on-surface-variant font-medium leading-relaxed">{s.descriptions[lang]}</p>
                <div class="mt-5 flex items-center gap-1.5 text-sm font-semibold text-primary">
                  {svc.details}
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ===== PORTS ===== -->
  <section class="py-20 md:py-28 bg-surface" id="ports">
    <div class="container-narrow">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-14">
        <div>
          <span class="label-gold">{lang === 'tr' ? 'HİZMET ALANLARIMIZ' : lang === 'ru' ? 'НАША ГЕОГРАФИЯ' : lang === 'zh' ? '我们的覆盖范围' : lang === 'es' ? 'NUESTRO ALCANCE' : lang === 'ar' ? 'نطاق خدماتنا' : lang === 'fr' ? 'NOTRE COUVERTURE' : 'OUR REACH'}</span>
          <h2 class="mt-3 section-title">{prt.title}</h2>
          <p class="section-subtitle max-w-2xl">{prt.subtitle}</p>
        </div>
        <a href={`/${lang}/${slugs.ports[lang]}/`} class="btn-secondary self-start md:self-auto !py-3 !px-6 text-sm flex-shrink-0">
          {prt.viewAll}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Region Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {regionOrder.map((regionKey, ri) => {
          const regionPorts = getPortsByRegion(regionKey);
          if (regionPorts.length === 0) return null;
          const gradients = [
            'from-blue-600/90 to-indigo-800/90',
            'from-cyan-600/90 to-blue-800/90',
            'from-amber-600/90 to-orange-800/90',
            'from-slate-600/90 to-slate-800/90',
          ];
          return (
            <div class="rounded-2xl overflow-hidden relative group">
              {/* Background image */}
              <div class="absolute inset-0">
                <img src="/images/port-generic.webp" alt="Turkish port panorama" class="w-full h-full object-cover" loading="lazy" />
                <div class={`absolute inset-0 bg-gradient-to-br ${gradients[ri]}`}></div>
              </div>
              {/* Content */}
              <div class="relative p-7 md:p-8">
                <div class="flex items-center gap-2 mb-4">
                  <span class="w-6 h-[2px] bg-gold-400 rounded-full"></span>
                  <h3 class="text-sm font-extrabold text-white/80 uppercase tracking-label">{regions[regionKey]?.[lang]}</h3>
                </div>
                <div class="text-3xl font-extrabold text-white mb-5">{regionPorts.length}<span class="text-base font-semibold text-white/50 ml-2">{lang === 'tr' ? 'Liman' : lang === 'ru' ? 'Портов' : lang === 'zh' ? '个港口' : lang === 'es' ? 'Puertos' : lang === 'ar' ? 'ميناء' : lang === 'fr' ? 'Ports' : 'Ports'}</span></div>
                <div class="flex flex-wrap gap-1.5">
                  {regionPorts.map(p => (
                    <a href={`/${lang}/${slugs.ports[lang]}/${p.id}/`}
                       class="inline-block px-3 py-1.5 rounded-lg bg-white/10 backdrop-blur-sm text-xs font-semibold text-white/90 hover:bg-white/25 hover:text-white transition-all duration-200">
                      {p.names[lang]}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ===== WHY US ===== -->
  <section class="relative py-20 md:py-28 overflow-hidden" style="background: linear-gradient(135deg, #1A2A60 0%, #243880 50%, #3D5099 100%);" id="why-us">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;80&quot; height=&quot;80&quot; viewBox=&quot;0 0 80 80&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23ffffff&quot;%3E%3Ccircle cx=&quot;40&quot; cy=&quot;40&quot; r=&quot;1.5&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="container-narrow relative">
      <span class="label text-gold-400/80">{lang === 'tr' ? 'NEDEN BİZ?' : lang === 'ru' ? 'ПОЧЕМУ МЫ' : lang === 'zh' ? '为什么选择我们' : lang === 'es' ? 'POR QUÉ ELEGIRNOS' : lang === 'ar' ? 'لماذا نحن' : lang === 'fr' ? 'POURQUOI NOUS' : 'WHY CHOOSE US'}</span>
      <h2 class="mt-3 text-3xl md:text-4xl font-extrabold text-white tracking-tight">{whyUs.title}</h2>
      <p class="mt-4 text-lg text-white/50 font-medium max-w-2xl">{whyUs.subtitle}</p>

      <div class="mt-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {whyUs.items.slice(0, 6).map((item: any, i: number) => (
          <div class="rounded-xl p-7 transition-all duration-200" style="background: rgba(255,255,255,0.05); backdrop-filter: blur(24px);">
            <div class="w-10 h-10 rounded-xl bg-gold-500/15 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                {i === 0 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>}
                {i === 1 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>}
                {i === 2 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>}
                {i === 3 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>}
                {i === 4 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>}
                {i === 5 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>}
              </svg>
            </div>
            <h3 class="text-base font-extrabold text-white">{item.title}</h3>
            <p class="mt-2 text-sm text-white/50 font-medium leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="py-20 md:py-28 bg-surface" id="faq">
    <div class="container-narrow">
      <div class="max-w-3xl mx-auto">
        <span class="label-gold">{lang === 'tr' ? 'DESTEK' : lang === 'ru' ? 'ПОДДЕРЖКА' : lang === 'zh' ? '支持' : lang === 'es' ? 'SOPORTE' : lang === 'ar' ? 'الدعم' : lang === 'fr' ? 'SUPPORT' : 'SUPPORT'}</span>
        <h2 class="mt-3 section-title">{faq.title}</h2>

        <div class="mt-12 space-y-3">
          {faq.items.map((item: any, i: number) => (
            <details class="group rounded-xl bg-surface-container-lowest overflow-hidden transition-all hover:shadow-ambient-sm" open={i === 0}>
              <summary class="flex items-center justify-between cursor-pointer px-7 py-5 text-left font-semibold text-on-surface hover:text-primary transition-colors">
                <span class="pr-4">{item.q}</span>
                <svg class="w-5 h-5 text-on-surface-variant group-open:rotate-180 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-7 pb-5 text-sm text-on-surface-variant font-medium leading-relaxed">{item.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="py-16 md:py-20 bg-surface-container-low">
    <div class="container-narrow">
      <div class="rounded-2xl p-10 md:p-14 text-center" style="background: linear-gradient(135deg, #1A2A60, #3D5099);">
        <h2 class="text-2xl md:text-3xl font-extrabold text-white tracking-tight">
          {lang === 'tr' ? 'Acil teklif mi gerekiyor?' : lang === 'ru' ? 'Нужна срочная цена?' : lang === 'zh' ? '需要紧急报价？' : lang === 'es' ? '¿Necesita una cotización urgente?' : lang === 'ar' ? 'هل تحتاج عرض سعر عاجل؟' : lang === 'fr' ? 'Besoin d\'un devis urgent ?' : 'Need an urgent quote?'}
        </h2>
        <p class="mt-3 text-base text-white/50 font-medium max-w-lg mx-auto">{contact.subtitle}</p>
        <div class="mt-8 flex flex-col sm:flex-row justify-center gap-3">
          <a href={`/${lang}/${slugs.contact[lang]}/`} class="btn-gold text-base !py-4 !px-10">
            {lang === 'tr' ? 'Teklif Alın' : lang === 'ru' ? 'Запросить цену' : lang === 'zh' ? '获取报价' : lang === 'es' ? 'Solicitar Cotización' : lang === 'ar' ? 'اطلب عرض سعر' : lang === 'fr' ? 'Demander un Devis' : 'Request a Quote'}
