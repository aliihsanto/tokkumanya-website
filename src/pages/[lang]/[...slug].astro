---
import BaseLayout from '@layouts/BaseLayout.astro';
import { LANGUAGES, type Lang, t, tReplace, slugs, langConfigs } from '@data/i18n';
import { ports, regions, getPortBySlug, getPortsByRegion, getNearbyPorts, type Port } from '@data/ports';
import { services, getServiceById, type Service } from '@data/services';
import { keywordPatterns, type KeywordPattern } from '@data/keywords';
import { references, referenceTranslations } from '@data/references';

const SITE = import.meta.env.SITE ?? '';

type PageType = 'port' | 'port-list' | 'service' | 'service-list' | 'port-service' | 'port-keyword' | 'references' | 'about' | 'contact';
interface PageData { type: PageType; port?: Port; service?: Service; keyword?: KeywordPattern; }

export function getStaticPaths() {
  const paths: any[] = [];
  for (const lang of LANGUAGES) {
    paths.push({ params: { lang, slug: slugs.ports[lang] }, props: { lang, pageData: { type: 'port-list' } } });
    for (const port of ports) {
      paths.push({ params: { lang, slug: `${slugs.ports[lang]}/${port.id}` }, props: { lang, pageData: { type: 'port', port } } });
      // Port + Service combo pages (programmatic SEO)
      for (const service of services) {
        const serviceSlug = slugs.serviceIds[service.id]?.[lang] ?? service.id;
        paths.push({
          params: { lang, slug: `${slugs.ports[lang]}/${port.id}/${serviceSlug}` },
          props: { lang, pageData: { type: 'port-service', port, service } },
        });
      }
    }
    paths.push({ params: { lang, slug: slugs.services[lang] }, props: { lang, pageData: { type: 'service-list' } } });
    for (const service of services) {
      const serviceSlug = slugs.serviceIds[service.id]?.[lang] ?? service.id;
      paths.push({ params: { lang, slug: `${slugs.services[lang]}/${serviceSlug}` }, props: { lang, pageData: { type: 'service', service } } });
    }
    // Keyword pages (port × keyword combos)
    for (const port of ports) {
      for (const kw of keywordPatterns) {
        paths.push({
          params: { lang, slug: `${slugs.ports[lang]}/${port.id}/${kw.slugs[lang]}` },
          props: { lang, pageData: { type: 'port-keyword', port, keyword: kw } },
        });
      }
    }
    // References page
    paths.push({ params: { lang, slug: slugs.references[lang] }, props: { lang, pageData: { type: 'references' } } });
    paths.push({ params: { lang, slug: slugs.about[lang] }, props: { lang, pageData: { type: 'about' } } });
    paths.push({ params: { lang, slug: slugs.contact[lang] }, props: { lang, pageData: { type: 'contact' } } });
  }
  return paths;
}

const { lang, pageData } = Astro.props as { lang: Lang; pageData: PageData };
const { type } = pageData;

let title = '', description = '', canonicalPath = '';
let schema: any = undefined;
let alternates: { lang: Lang; path: string }[] = [];

if (type === 'port' && pageData.port) {
  const p = pageData.port; const pn = p.names[lang]; const rn = regions[p.region]?.[lang] ?? '';
  title = tReplace(t(lang, 'portPage.metaTitle'), { port: pn }); description = tReplace(t(lang, 'portPage.metaDesc'), { port: pn, region: rn });
  canonicalPath = `/${lang}/${slugs.ports[lang]}/${p.id}/`; alternates = LANGUAGES.map(l => ({ lang: l as Lang, path: `/${l}/${slugs.ports[l]}/${p.id}/` }));
  schema = { "@context":"https://schema.org","@type":"Service","name":title,"description":description,"provider":{"@type":"Organization","name":"Tok Ship Supply","url":SITE},"areaServed":{"@type":"Place","name":pn,"geo":{"@type":"GeoCoordinates","latitude":p.lat,"longitude":p.lng}},"serviceType":"Ship Supply & Provisioning" };
} else if (type === 'port-service' && pageData.port && pageData.service) {
  const p = pageData.port; const s = pageData.service; const pn = p.names[lang]; const sn = s.names[lang]; const rn = regions[p.region]?.[lang] ?? '';
  const ss = slugs.serviceIds[s.id]?.[lang] ?? s.id;
  title = tReplace(t(lang, 'portServicePage.metaTitle'), { port: pn, service: sn });
  description = tReplace(t(lang, 'portServicePage.metaDesc'), { port: pn, service: sn, region: rn });
  canonicalPath = `/${lang}/${slugs.ports[lang]}/${p.id}/${ss}/`;
  alternates = LANGUAGES.map(l => ({ lang: l as Lang, path: `/${l}/${slugs.ports[l]}/${p.id}/${slugs.serviceIds[s.id]?.[l] ?? s.id}/` }));
  schema = {
    "@context":"https://schema.org","@type":"Service",
    "name": title, "description": description,
    "provider":{"@type":"Organization","name":"Tok Ship Supply","url":SITE},
    "areaServed":{"@type":"Place","name":pn,"geo":{"@type":"GeoCoordinates","latitude":p.lat,"longitude":p.lng}},
    "serviceType": sn, "category": sn
  };
} else if (type === 'port-list') {
  title = `${t(lang, 'ports.allPorts')} | Tok Ship Supply`; description = t(lang, 'siteDescription');
  canonicalPath = `/${lang}/${slugs.ports[lang]}/`; alternates = LANGUAGES.map(l => ({ lang: l as Lang, path: `/${l}/${slugs.ports[l]}/` }));
} else if (type === 'service' && pageData.service) {
  const s = pageData.service; const sn = s.names[lang]; const ss = slugs.serviceIds[s.id]?.[lang] ?? s.id;
  title = tReplace(t(lang, 'servicePage.metaTitle'), { service: sn }); description = tReplace(t(lang, 'servicePage.metaDesc'), { service: sn });
  canonicalPath = `/${lang}/${slugs.services[lang]}/${ss}/`; alternates = LANGUAGES.map(l => ({ lang: l as Lang, path: `/${l}/${slugs.services[l]}/${slugs.serviceIds[s.id]?.[l] ?? s.id}/` }));
} else if (type === 'service-list') {
  title = `${t(lang, 'nav.services')} | Tok Ship Supply`; description = t(lang, 'services.subtitle');
  canonicalPath = `/${lang}/${slugs.services[lang]}/`; alternates = LANGUAGES.map(l => ({ lang: l as Lang, path: `/${l}/${slugs.services[l]}/` }));
} else if (type === 'port-keyword' && pageData.port && pageData.keyword) {
  const p = pageData.port; const kw = pageData.keyword; const pn = p.names[lang]; const rn = regions[p.region]?.[lang] ?? '';
  title = tReplace(kw.titles[lang] ?? kw.titles.en, { port: pn, region: rn });
  description = tReplace(kw.descriptions[lang] ?? kw.descriptions.en, { port: pn, region: rn });
  canonicalPath = `/${lang}/${slugs.ports[lang]}/${p.id}/${kw.slugs[lang]}/`;
  alternates = LANGUAGES.map(l => ({ lang: l as Lang, path: `/${l}/${slugs.ports[l]}/${p.id}/${kw.slugs[l]}/` }));
  schema = { "@context":"https://schema.org","@type":"Service","name":title,"description":description,"provider":{"@type":"Organization","name":"Tok Ship Supply"},"areaServed":{"@type":"Place","name":pn} };
} else if (type === 'references') {
  title = referenceTranslations.metaTitle[lang]; description = referenceTranslations.metaDesc[lang];
  canonicalPath = `/${lang}/${slugs.references[lang]}/`; alternates = LANGUAGES.map(l => ({ lang: l as Lang, path: `/${l}/${slugs.references[l]}/` }));
} else if (type === 'about') {
  title = t(lang, 'aboutPage.metaTitle'); description = t(lang, 'aboutPage.metaDesc');
  canonicalPath = `/${lang}/${slugs.about[lang]}/`; alternates = LANGUAGES.map(l => ({ lang: l as Lang, path: `/${l}/${slugs.about[l]}/` }));
} else if (type === 'contact') {
  title = t(lang, 'contactPage.metaTitle'); description = t(lang, 'contactPage.metaDesc');
  canonicalPath = `/${lang}/${slugs.contact[lang]}/`; alternates = LANGUAGES.map(l => ({ lang: l as Lang, path: `/${l}/${slugs.contact[l]}/` }));
}

const breadcrumbHome = t(lang, 'breadcrumb.home');
const regionOrder = ['marmara', 'aegean', 'mediterranean', 'black-sea'];

const serviceIconPaths = [
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>`,
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>`,
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8V4m0 4a4 4 0 110 8 4 4 0 010-8zm0 8v4m-4-4h8"/>`,
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.573-1.066z"/><circle cx="12" cy="12" r="3"/>`,
];
---

<BaseLayout title={title} description={description} lang={lang} canonicalPath={canonicalPath} alternates={alternates} schema={schema}>

  <!-- Breadcrumb -->
  <nav class="bg-surface-container-low" aria-label="Breadcrumb">
    <div class="container-narrow py-3.5">
      <ol class="flex items-center gap-2 text-sm font-medium text-on-surface-variant flex-wrap" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href={`/${lang}/`} class="hover:text-primary transition-colors" itemprop="item"><span itemprop="name">{breadcrumbHome}</span></a><meta itemprop="position" content="1" />
        </li>
        {(type === 'port' || type === 'port-list' || type === 'port-service') && (<><li class="text-outline/40">/</li><li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href={`/${lang}/${slugs.ports[lang]}/`} class="hover:text-primary transition-colors" itemprop="item"><span itemprop="name">{t(lang, 'nav.ports')}</span></a>
          <meta itemprop="position" content="2" /></li></>)}
        {type === 'port' && pageData.port && (<><li class="text-outline/40">/</li><li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"><span class="text-on-surface font-semibold" itemprop="name">{pageData.port.names[lang]}</span><meta itemprop="position" content="3" /></li></>)}
        {type === 'port-service' && pageData.port && pageData.service && (<>
          <li class="text-outline/40">/</li>
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a href={`/${lang}/${slugs.ports[lang]}/${pageData.port.id}/`} class="hover:text-primary transition-colors" itemprop="item"><span itemprop="name">{pageData.port.names[lang]}</span></a>
            <meta itemprop="position" content="3" />
          </li>
          <li class="text-outline/40">/</li>
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <span class="text-on-surface font-semibold" itemprop="name">{pageData.service.names[lang]}</span>
            <meta itemprop="position" content="4" />
          </li>
        </>)}
        {(type === 'service' || type === 'service-list') && (<><li class="text-outline/40">/</li><li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          {type === 'service-list' ? <span class="text-on-surface font-semibold" itemprop="name">{t(lang, 'nav.services')}</span> : <a href={`/${lang}/${slugs.services[lang]}/`} class="hover:text-primary transition-colors" itemprop="item"><span itemprop="name">{t(lang, 'nav.services')}</span></a>}
          <meta itemprop="position" content="2" /></li></>)}
        {type === 'service' && pageData.service && (<><li class="text-outline/40">/</li><li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"><span class="text-on-surface font-semibold" itemprop="name">{pageData.service.names[lang]}</span><meta itemprop="position" content="3" /></li></>)}
        {type === 'port-keyword' && pageData.port && pageData.keyword && (<>
          <li class="text-outline/40">/</li>
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"><a href={`/${lang}/${slugs.ports[lang]}/${pageData.port.id}/`} class="hover:text-primary transition-colors" itemprop="item"><span itemprop="name">{pageData.port.names[lang]}</span></a><meta itemprop="position" content="3" /></li>
          <li class="text-outline/40">/</li>
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"><span class="text-on-surface font-semibold" itemprop="name">{tReplace(pageData.keyword.h1[lang] ?? '', { port: '' }).trim()}</span><meta itemprop="position" content="4" /></li>
        </>)}
        {type === 'references' && (<><li class="text-outline/40">/</li><li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"><span class="text-on-surface font-semibold" itemprop="name">{referenceTranslations.title[lang]}</span><meta itemprop="position" content="2" /></li></>)}
        {type === 'about' && (<><li class="text-outline/40">/</li><li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"><span class="text-on-surface font-semibold" itemprop="name">{t(lang, 'nav.about')}</span><meta itemprop="position" content="2" /></li></>)}
        {type === 'contact' && (<><li class="text-outline/40">/</li><li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"><span class="text-on-surface font-semibold" itemprop="name">{t(lang, 'nav.contact')}</span><meta itemprop="position" content="2" /></li></>)}
      </ol>
    </div>
  </nav>

  <!-- ========== PORT PAGE ========== -->
  {type === 'port' && pageData.port && (() => {
    const port = pageData.port!; const portName = port.names[lang]; const regionName = regions[port.region]?.[lang] ?? '';
    const pp = t(lang, 'portPage'); const nearby = getNearbyPorts(port.id);
    return (<>
      {/* Hero */}
      <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #1A2A60 0%, #243880 40%, #3D5099 100%);">
        <div class="absolute inset-0 opacity-[0.04]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;80&quot; height=&quot;80&quot; viewBox=&quot;0 0 80 80&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23ffffff&quot;%3E%3Ccircle cx=&quot;40&quot; cy=&quot;40&quot; r=&quot;1.5&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
        <div class="container-narrow relative py-16 md:py-24 lg:py-28">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
            <div>
              <span class="label-gold">{lang === 'tr' ? 'GÜVENİLİR GEMİ TEDARİK ORTAĞINIZ' : 'TRUSTED SHIP SUPPLY PARTNER'}</span>
              <h1 class="mt-4 text-3xl md:text-4xl lg:text-5xl font-extrabold text-white leading-[1.1] tracking-tight">
                {tReplace(pp.heroTitle, { port: portName })}<span class="text-gold-400">.</span>
              </h1>
              <p class="mt-5 text-base md:text-lg text-white/55 font-medium leading-relaxed max-w-lg">{tReplace(pp.heroSubtitle, { port: portName })}</p>
              <div class="mt-8 flex flex-col sm:flex-row gap-3">
                <a href="https://wa.me/905459477320" target="_blank" rel="noopener noreferrer" class="btn-whatsapp !py-3.5 !px-8">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                  WhatsApp
                </a>
                <a href="tel:+905459477320" class="btn-gold !py-3.5 !px-8">+90 545 947 73 20</a>
              </div>
            </div>
            <div class="hidden lg:block">
              <div class="rounded-2xl overflow-hidden aspect-[4/3] bg-white/5 backdrop-blur-sm flex items-center justify-center">
                <div class="text-center p-8">
                  <div class="w-16 h-16 mx-auto rounded-2xl bg-gold-500/15 flex items-center justify-center mb-4">
                    <svg class="w-8 h-8 text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  </div>
                  <p class="text-white/40 font-semibold text-sm">{pp.regionInfo}</p>
                  <p class="text-white font-extrabold text-xl mt-1">{regionName}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="wave-divider"><svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-[40px] md:h-[60px] block" fill="#fcf8fb"><path d="M0 60h1440V20Q1080 60 720 40T0 50z"/></svg></div>
      </section>

      {/* Services at Port */}
      <section class="py-20 md:py-28 bg-surface">
        <div class="container-narrow">
          <span class="label-gold">{lang === 'tr' ? 'LIMAN LOJİSTİĞİ VE TEDARİK' : 'PORT LOGISTICS & SUPPLY'}</span>
          <h2 class="mt-3 section-title">{tReplace(pp.servicesTitle, { port: portName })}</h2>
          <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {services.map((s, i) => {
              const sSlug = slugs.serviceIds[s.id]?.[lang] ?? s.id;
              return (
                <a href={`/${lang}/${slugs.ports[lang]}/${port.id}/${sSlug}/`}
                   class="group rounded-xl bg-surface-container-lowest overflow-hidden transition-all duration-300 hover:shadow-ambient">
                  <div class="aspect-[16/10] overflow-hidden">
                    <img src={s.image} alt={`${portName} ${s.names[lang]}`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width="400" height="250" loading="lazy" />
                  </div>
                  <div class="p-6">
                    <h3 class="text-base font-extrabold text-on-surface group-hover:text-primary transition-colors">{s.names[lang]}</h3>
                    <p class="mt-2 text-sm text-on-surface-variant font-medium leading-relaxed line-clamp-2">{s.descriptions[lang]}</p>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </section>

      {/* Nearby Ports */}
      {nearby.length > 0 && (
        <section class="py-20 md:py-28 bg-surface-container-low">
          <div class="container-narrow">
            <span class="label-gold">{lang === 'tr' ? 'YAKIN LİMANLAR' : 'NEARBY PORTS'}</span>
            <h2 class="mt-3 section-title">{pp.nearbyTitle}</h2>
            <p class="section-subtitle max-w-2xl">{tReplace(pp.nearbySubtitle, { port: portName })}</p>
            <div class="mt-10 flex flex-wrap gap-3">
              {nearby.map(np => (
                <a href={`/${lang}/${slugs.ports[lang]}/${np.id}/`}
                   class="inline-flex items-center gap-2 px-5 py-3 rounded-xl bg-surface-container-lowest text-sm font-semibold text-on-surface-variant hover:text-primary hover:shadow-ambient-sm transition-all duration-200">
                  <svg class="w-4 h-4 text-ocean-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                  {np.names[lang]}
                </a>
              ))}
            </div>
          </div>
        </section>
      )}

      {/* Contact Info + CTA */}
      <section class="py-16 md:py-20 bg-surface">
        <div class="container-narrow">
          <div class="rounded-2xl p-10 md:p-14" style="background: linear-gradient(135deg, #1A2A60, #3D5099);">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
              <div>
                <h2 class="text-2xl md:text-3xl font-extrabold text-white tracking-tight">{tReplace(pp.ctaTitle, { port: portName })}</h2>
                <p class="mt-3 text-base text-white/50 font-medium">{pp.ctaSubtitle}</p>
              </div>
              <div class="flex flex-col sm:flex-row gap-3 lg:justify-end">
                <a href="https://wa.me/905459477320" target="_blank" rel="noopener noreferrer" class="btn-whatsapp !py-3.5 !px-8">WhatsApp</a>
                <a href="tel:+905459477320" class="btn-gold !py-3.5 !px-8">+90 545 947 73 20</a>
              </div>
            </div>
          </div>
        </div>
      </section>
    </>);
  })()}

  <!-- ========== PORT + SERVICE PAGE ========== -->
  {type === 'port-service' && pageData.port && pageData.service && (() => {
