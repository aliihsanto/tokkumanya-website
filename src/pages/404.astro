---
import '@/styles/global.css';
---
<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>404 - Sayfa Bulunamadı | Tok Ship Supply</title>
  <meta name="robots" content="noindex" />
  <link rel="icon" type="image/png" href="/logo/icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800&display=swap" />
</head>
<body class="min-h-screen flex items-center justify-center bg-surface font-sans text-on-surface antialiased">
  <div class="text-center px-6 py-20">
    <!-- Animated anchor icon -->
    <div class="relative inline-block mb-8">
      <div class="w-24 h-24 rounded-2xl mx-auto flex items-center justify-center" style="background: linear-gradient(135deg, #243880, #3D5099);">
        <svg class="w-12 h-12 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="animation: float 3s ease-in-out infinite;">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8V4m0 4a4 4 0 110 8 4 4 0 010-8zm0 8v4m-4-4h8"/>
        </svg>
      </div>
    </div>

    <h1 class="text-6xl md:text-8xl font-extrabold tracking-tight" style="background: linear-gradient(135deg, #243880, #3D5099); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">404</h1>
    <p class="mt-4 text-xl md:text-2xl font-extrabold text-on-surface">Sayfa Bulunamadı</p>
    <p class="mt-3 text-base text-on-surface-variant font-medium max-w-md mx-auto">
      Aradığınız sayfa mevcut değil veya taşınmış olabilir. Ana sayfaya dönebilir veya aşağıdaki bağlantıları kullanabilirsiniz.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row justify-center gap-3">
      <a href="/tr/" class="inline-flex items-center justify-center gap-2 rounded-xl px-7 py-3.5 text-sm font-semibold text-white" style="background: linear-gradient(135deg, #243880, #3D5099);">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Ana Sayfa
      </a>
      <a href="/tr/limanlar/" class="inline-flex items-center justify-center gap-2 rounded-xl px-7 py-3.5 text-sm font-semibold bg-surface-container-low text-on-surface-variant hover:bg-surface-container-high transition-all">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
        Limanlar
      </a>
      <a href="https://wa.me/905459477320" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 rounded-xl bg-green-600 px-7 py-3.5 text-sm font-semibold text-white hover:bg-green-700 transition-all">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
        WhatsApp
      </a>
    </div>

    <!-- Language links -->
    <div class="mt-12 flex justify-center gap-3 flex-wrap">
      {['🇹🇷 TR', '🇬🇧 EN', '🇷🇺 RU', '🇨🇳 ZH', '🇪🇸 ES', '🇸🇦 AR', '🇫🇷 FR'].map((l, i) => {
        const codes = ['tr', 'en', 'ru', 'zh', 'es', 'ar', 'fr'];
        return <a href={`/${codes[i]}/`} class="text-xs font-semibold text-on-surface-variant hover:text-primary px-2 py-1 rounded-lg hover:bg-surface-container-low transition-all">{l}</a>;
      })}
    </div>
  </div>

  <style>
    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-8px); }
    }
  </style>
</body>
</html>
