---
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { type Lang, langConfigs, LANGUAGES, isRTL, t } from '@data/i18n';
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  canonicalPath?: string;
  alternates?: { lang: Lang; path: string }[];
  schema?: object;
  ogImage?: string;
}

const { title, description, lang, canonicalPath, alternates, schema, ogImage } = Astro.props;
const dir = isRTL(lang) ? 'rtl' : 'ltr';
const SITE = import.meta.env.SITE ?? Astro.site?.origin ?? '';
const canonicalURL = canonicalPath ? `${SITE}${canonicalPath}` : Astro.url.href;
const ogImg = ogImage ?? `${SITE}/images/og-preview.webp`;
---
<!DOCTYPE html>
<html lang={langConfigs[lang].hreflang} dir={dir}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Favicons (defined below) -->

  <!-- Hreflang -->
  {alternates?.map(alt => (
    <link rel="alternate" hreflang={langConfigs[alt.lang].hreflang} href={`${SITE}${alt.path}`} />
  ))}
  {alternates && <link rel="alternate" hreflang="x-default" href={`${SITE}${alternates.find(a => a.lang === 'en')?.path ?? alternates[0]?.path}`} />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImg} />
  <meta property="og:site_name" content="Tok Ship Supply" />
  <meta property="og:locale" content={langConfigs[lang].hreflang} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImg} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#243880" />

  <!-- Google Search Console Verification - Replace with your code -->
  <!-- <meta name="google-site-verification" content="YOUR_VERIFICATION_CODE" /> -->

  <!-- Google Analytics - Uncomment and add your ID when ready -->
  <!--
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config','G-XXXXXXXXXX');</script>
  -->

  <!-- Inter font: non-blocking with swap -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Preload hero image for LCP -->
  <link rel="preload" as="image" href="/images/hero.webp" type="image/webp" />

  <!-- Schema.org -->
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

  <!-- WebSite + SearchAction Schema (Sitelinks Search Box) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Tok Ship Supply",
    "alternateName": "Tok Kumanya",
    "url": SITE,
    "inLanguage": LANGUAGES.map(l => langConfigs[l].hreflang),
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": `${SITE}/{lang}/?q={search_term_string}` },
      "query-input": "required name=search_term_string"
    }
  })} />

  <!-- LocalBusiness + Organization Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "Organization"],
    "name": "Tok Ship Supply Co.",
    "alternateName": "Tok Kumanya",
    "url": SITE,
    "logo": `${SITE}/logo/logo.png`,
    "image": `${SITE}/images/hero.webp`,
    "description": t(lang, 'siteDescription'),
    "foundingDate": "2005",
    "numberOfEmployees": { "@type": "QuantitativeValue", "minValue": 20, "maxValue": 50 },
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Karasamsun Mah. Yıldıray Çınar Bulvarı 848.Sokak No:2/B",
      "addressLocality": "İlkadım",
      "addressRegion": "Samsun",
      "postalCode": "55060",
      "addressCountry": "TR"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": 41.2867, "longitude": 36.3300 },
    "contactPoint": [
      { "@type": "ContactPoint", "telephone": "+90-545-947-7320", "contactType": "sales", "availableLanguage": ["Turkish", "English", "Russian"], "areaServed": "TR" },
      { "@type": "ContactPoint", "telephone": "+90-543-741-7955", "contactType": "customer service", "availableLanguage": ["Turkish"] },
      { "@type": "ContactPoint", "telephone": "+90-362-445-2560", "contactType": "reservations", "availableLanguage": ["Turkish"] }
    ],
    "telephone": "+90-545-947-7320",
    "email": "info@tokkumanya.com",
    "openingHoursSpecification": { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"], "opens": "00:00", "closes": "23:59" },
    "priceRange": "$$",
    "paymentAccepted": ["Cash", "Credit Card", "Bank Transfer"],
    "currenciesAccepted": "TRY, USD, EUR",
    "areaServed": { "@type": "Country", "name": "Turkey" },
    "serviceType": ["Ship Chandlery", "Ship Provisioning", "Marine Supply", "Cold Chain Delivery"],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Ship Supply Services",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Food Provisions" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Fresh Produce Supply" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Cabin & Cleaning Supplies" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Safety Equipment" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Deck Supplies" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Technical & Engine Room Supplies" } }
      ]
    },
    "sameAs": ["https://www.instagram.com/tokshipsupply"],
    "memberOf": [
      { "@type": "Organization", "name": "ISSA - International Ship Suppliers Association" },
      { "@type": "Organization", "name": "TURSSA - Türkiye Gemi Tedarikçileri Derneği" }
    ],
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "284", "bestRating": "5" }
  })} />
</head>
<body class="min-h-screen flex flex-col bg-white text-gray-800">
  <Header lang={lang} alternates={alternates} />
  <main class="flex-1">
    <slot />
  </main>
  <Footer lang={lang} />
</body>
</html>
